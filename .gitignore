# ==========================
# macOS
# ==========================
.DS_Store

# ==========================
# Node.js (applies everywhere)
# ==========================
node_modules/
npm-debug.log*
yarn-error.log*

# ==========================
# React Native (frontend)
# ==========================

# iOS / Xcode
frontend/build/
frontend/*.pbxuser
!frontend/default.pbxuser
frontend/*.mode1v3
!frontend/default.mode1v3
frontend/*.mode2v3
!frontend/default.mode2v3
frontend/*.perspectivev3
!frontend/default.perspectivev3
frontend/xcuserdata/
frontend/DerivedData/
frontend/*.hmap
frontend/*.ipa
frontend/*.xcuserstate
frontend/**/*.xcode.env.local

# Android
frontend/.idea/
frontend/.gradle/
frontend/local.properties
frontend/*.iml
frontend/*.hprof
frontend/.cxx/
frontend/*.keystore
!frontend/debug.keystore
frontend/.kotlin/

# Metro
frontend/.metro-health-check*

# Bundle
frontend/*.jsbundle

# CocoaPods
frontend/**/Pods/
frontend/vendor/bundle/

# Fastlane
frontend/**/fastlane/report.xml
frontend/**/fastlane/Preview.html
frontend/**/fastlane/screenshots/
frontend/**/fastlane/test_output/

# Coverage
frontend/coverage/

# Yarn
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/sdks
!frontend/.yarn/versions

# ==========================
# Environment files
# ==========================
.env
.env.*
!.env.example